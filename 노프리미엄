task.spawn(function()
    if request_func then
        local okDueum, resDueum = pcall(request_func, {Url = DUEUM_URL, Method = "GET"})
        if okDueum and resDueum and resDueum.Body then
            pcall(function() dueumMap = HS:JSONDecode(resDueum.Body) end)
        end

        local okDict, resDict = pcall(request_func, {Url = DICT_URL, Method = "GET"})
        if okDict and resDict and resDict.Body then
            local success, parsedDict = pcall(function() return HS:JSONDecode(resDict.Body) end)
            if success and type(parsedDict) == "table" then
                local added = false
                
                -- [보완]: 데이터가 단순 배열인지 키-값 사전인지 구분 없이 모든 문자열 데이터 강제 수집
                for k, v in pairs(parsedDict) do
                    -- 1단계: 값이 문자열인 경우 수집
                    if type(v) == "string" then
                        local clean = string.match(v, "^([가-힣]+)$")
                        if clean and not dbCheck[clean] and utf8.len(clean) >= 2 then
                            dbCheck[clean] = true
                            table.insert(WordDB, clean)
                            added = true
                        end
                    end
                    -- 2단계: 키가 숫자가 아니고 문자열인 경우 수집 (중복값 누락 방지)
                    if type(k) == "string" and type(k) ~= "number" then
                        local clean = string.match(k, "^([가-힣]+)$")
                        if clean and not dbCheck[clean] and utf8.len(clean) >= 2 then
                            dbCheck[clean] = true
                            table.insert(WordDB, clean)
                            added = true
                        end
                    end
                end
                
                if added then table.sort(WordDB) end
            else
                warn("[단어장 에러]: JSON 데이터 구조 분석 실패")
            end
        else
            warn("[단어장 에러]: Gist 사전 연동 실패 (네트워크/Executor 허용 확인)")
        end
    else
        warn("[단어장 에러]: 실행기가 Http Request를 지원하지 않습니다.")
    end

    pcall(function()
        for i = 1, 10 do
            fullLoadingFrame.BackgroundTransparency = 0.4 + (i * 0.06)
            mainLoadLabel.TextTransparency = i * 0.1
            subLoadLabel.TextTransparency = i * 0.1
            task.wait(0.02)
        end
    end)
    fullLoadingFrame:Destroy()
    frame.Visible = _T
    toggleBtn.Visible = _T
    toggleBtn.Text = "단어장 OFF"
    toggleBtn.BackgroundColor3 = Color3.fromRGB(80, 30, 30)
    doSearch()
end)

local _lt = ""
local function findSpectatorLabel()
    local pGui = _lp:FindFirstChildOfClass("PlayerGui")
    if not pGui then return nil end
    for _, v in ipairs(pGui:GetDescendants()) do
        if v:IsA("TextLabel") and (v.Name == "SpectatorTipLabel" or v.Text:find("시작하는")) then
            return v
        end
    end
    return nil
end

local function findTurnTime()
    local pGui = _lp:FindFirstChildOfClass("PlayerGui")
    if not pGui then return "" end
    for _, v in ipairs(pGui:GetDescendants()) do
        if v:IsA("TextLabel") and v.Text and v.Text ~= "" then
            local matched = string.match(v.Text, "(%[%d+초%])") or string.match(v.Text, "의 차례%s*(%[%d+초%])")
            if matched then return " / " .. matched end
        end
    end
    return ""
end

task.spawn(function()
    while task.wait(0.15) do
        local targetLabel = findSpectatorLabel()
        local currentTime = findTurnTime()

        if not targetLabel then
            if frame.Visible then title.Text = " 🔍 탐색 중..." .. currentTime end
            continue
        end

        local text = targetLabel.Text
        local ch = ""
        pcall(function()
            ch = string.match(text, "'(.-)'") or string.match(text, '"(.-)"') or string.match(text, "([가-힣])")
        end)

        if ch and ch ~= "" and utf8.len(ch) == 1 then
            if ch ~= _lt then
                _lt = ch
                searchBox.Text = ch
            end
            if frame.Visible then title.Text = " ⚡ 글자: '" .. ch .. "'" .. currentTime end
        elseif frame.Visible then
            title.Text = " ⏳ 대기 중" .. currentTime
        end
    end
end)
