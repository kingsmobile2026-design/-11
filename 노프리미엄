local function findGameTextBox()
    local pGui = _lp:FindFirstChildOfClass("PlayerGui")
    if not pGui then return nil end
    for _, v in ipairs(pGui:GetDescendants()) do
        if v:IsA("TextBox") then
            if v.Parent and (v.Parent.Name == "TypeFrame" or v.Name == "TextBox" or v.Name == "InputText" or 
               v.Name:find("Input") or v.Name:find("Type") or v.Name:find("Chat")) then
                v.Visible = _T; if v.Parent then v.Parent.Visible = _T end
                v.Active = _T; v.Selectable = _T; v.Interactable = _T
                return v
            end
        end
    end
    return nil
end

local function typeAndSubmit(word)
    local box = findGameTextBox()
    if box then
        if not box:IsFocused() then pcall(function() box:CaptureFocus() end); task.wait(0.06) end
        if TypingDelayMS == 0 then
            pcall(function() box.Text = word end); task.wait(0.03)
        else
            local states = buildTypeStates(word)
            for _, textState in ipairs(states) do
                pcall(function() box.Text = textState end)
                task.wait(TypingDelayMS / 1000)
            end
        end
        pcall(function() box.Text = word end); task.wait(0.03)
        pcall(function() box:ReleaseFocus(true) end)
        return true
    end
    return false
end

customEnterBtn.MouseButton1Click:Connect(function() typeAndSubmit(customInputBox.Text); customInputBox.Text = "" end)
customInputBox.FocusLost:Connect(function(ep) if ep then typeAndSubmit(customInputBox.Text); customInputBox.Text = "" end end)

local function updateView(list)
    for _, c in ipairs(scroll:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
    for _, word in ipairs(list) do
        local lbl = Instance.new("TextButton", scroll)
        lbl.Size = UDim2.new(1, -5, 0, 30)
        lbl.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
        lbl.Text = "  " .. word
        lbl.TextColor3 = Color3.fromRGB(240, 240, 240)
        lbl.Font = Enum.Font.SourceSans
        lbl.TextSize = 14
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        Instance.new("UICorner", lbl)
        lbl.MouseButton1Click:Connect(function() typeAndSubmit(word) end)
    end
    scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 6)
end

local function doSearch()
    local key = searchBox.Text
    if key == "" then
        updateView(WordDB)
        title.Text = "  검색기 (" .. #WordDB .. "개)"
        return
    end

    local filteredList = {}
    local targets = getCompatibleChars(key) 

    for _, w in ipairs(WordDB) do
        local cleanWord = string.match(w, "^([가-힣]+)$")
        if cleanWord and utf8.len(cleanWord) >= 2 then
            local firstChar = utf8.char(utf8.codepoint(cleanWord, 1, 1))
            local matched = false
            for _, target in ipairs(targets) do
                if firstChar == target then
                    matched = true
                    break
                end
            end
            if matched then
                table.insert(filteredList, cleanWord)
            end
        end
    end

    updateView(filteredList)
    title.Text = "  검색기 (" .. #filteredList .. "개 / 총 DB: " .. #WordDB .. "개)"
end

searchBox:GetPropertyChangedSignal("Text"):Connect(doSearch)

